generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique // теперь опциональный!
  emailVerified DateTime? // добавили
  image         String? // добавили
  password      String? // твоё кастомное поле
  role          String    @default("user") // твоё кастомное поле
  createdAt     DateTime  @default(now()) // можно оставить
  updatedAt     DateTime  @updatedAt // можно оставить

  accounts Account[]
  sessions Session[]
  orders   Order[] // твоя связь

  carts Cart[]

  reviews Review[]
}

// Добавить после модели User или в любое место

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([userId])
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int
  addedAt   DateTime @default(now())

  @@unique([cartId, productId]) 
  @@index([cartId])
  @@index([productId])
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  price       Float
  images      String
  inStock     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  averageRating Float @default(0)

  orderItems OrderItem[]

  categories Category[]
  cartItems  CartItem[]

  // Индексы для фильтрации
  @@index([price]) // для фильтра по цене
  @@index([inStock]) // для фильтра "в наличии"
  @@index([createdAt]) // для сортировки по новизне
  @@index([name]) // для поиска/сортировки по имени
  reviews Review[]
}

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
}

model Order {
  id     String  @id @default(cuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Данные покупателя (НОВЫЕ)
  fullName      String
  email         String
  phone         String
  address       String
  paymentMethod String // 'card' или 'cash'

  // Существующие поля
  status    String   @default("pending")
  total     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems OrderItem[]

  @@index([userId])
  @@index([status])
}

model OrderItem {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId    String
  productName  String // НОВОЕ: сохраняем название на момент заказа
  productPrice Float // переименовать priceAtTime -> productPrice для ясности
  quantity     Int

  // Опционально: связь с Product (если нужно)
  product Product? @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

enum OrderStatus {
  PENDING_PAYMENT  // ожидает оплаты
  PAID             // оплачен
  PROCESSING       // в обработке
  SHIPPED          // отправлен
  DELIVERED        // доставлен
  CANCELLED        // отменён
}

// Модели для PrismaAdapter
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Review {
  id        String   @id @default(cuid())
  rating    Int      // 1–5
  text      String   
  status    String   @default("pending") // pending / approved / rejected

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Один пользователь — один отзыв на товар
  @@unique([userId, productId])
  @@index([productId])
  @@index([status])
}
