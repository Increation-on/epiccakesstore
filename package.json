{
  "name": "epiccakesstore",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "vercel-build": "prisma generate && next build --webpack",
    "lint": "biome check",
    "format": "biome format --write",
    "type-check": "tsc --noEmit",
    "prisma:seed": "tsx prisma/seed.ts",
    "test:unit": "vitest run --environment jsdom",
    "test:e2e": "playwright test --workers=1",
    "test": "npm run test:unit && npm run test:e2e",
    "test:integration": "dotenv -e .env.test -- vitest run --config vitest.integration.config.ts --no-file-parallelism"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@hookform/resolvers": "^5.2.2",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@next/font": "^14.2.15",
    "@prisma/adapter-better-sqlite3": "^7.4.2",
    "@prisma/adapter-neon": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@prisma/pg-worker": "^6.9.0",
    "@stripe/react-stripe-js": "^5.6.1",
    "@stripe/stripe-js": "^8.9.0",
    "@vercel/blob": "^2.3.1",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.6.2",
    "date-fns": "^4.1.0",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "prisma": "^7.5.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "sharp": "^0.34.5",
    "slugify": "^1.6.6",
    "sonner": "^2.0.7",
    "stripe": "^20.4.1",
    "swiper": "^12.1.3",
    "use-debounce": "^10.1.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@electric-sql/pglite": "^0.4.1",
    "@neondatabase/serverless": "^1.0.2",
    "@playwright/test": "^1.59.1",
    "@prisma/adapter-pg": "^7.7.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sharp": "^0.31.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.2",
    "dotenv": "^17.3.1",
    "dotenv-cli": "^11.0.0",
    "happy-dom": "^20.8.9",
    "jsdom": "26.1.0",
    "pglite-prisma-adapter": "^0.7.2",
    "postgres": "^3.4.9",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
